# Canonical site URL for SEO (Open Graph, canonical links, sitemap). No trailing slash.
# PUBLIC_SITE_URL=https://slapmac.com

# Stripe Checkout verification (server-only) — /license and /api/license
# STRIPE_SECRET_KEY=sk_live_…

# MongoDB — license keys stored in `licenses` collection
# MONGODB_URI=mongodb+srv://…
# MONGODB_DB_NAME=slapmac
