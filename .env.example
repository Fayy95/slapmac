# Canonical site URL for SEO (Open Graph, canonicals, sitemap, JSON-LD). No trailing slash.
# Defaults to https://slapmymac.net if unset.
# PUBLIC_SITE_URL=https://www.slapmymac.net

# Stripe Checkout verification (server-only) — /license and /api/license
# STRIPE_SECRET_KEY=sk_live_…

# MongoDB — license keys stored in `licenses` collection
# MONGODB_URI=mongodb+srv://…
# MONGODB_DB_NAME=slapmac
